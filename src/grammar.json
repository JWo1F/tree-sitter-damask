{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "rsc",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_node"
      }
    },
    "_node": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "tag"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        }
      ]
    },
    "tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "open",
          "content": {
            "type": "SYMBOL",
            "name": "tag_open"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "code"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "close",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "STRING",
              "value": "}"
            },
            "named": true,
            "value": "tag_delimiter"
          }
        }
      ]
    },
    "tag_open": {
      "type": "ALIAS",
      "content": {
        "type": "TOKEN",
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "{#"
            },
            {
              "type": "STRING",
              "value": "{@"
            },
            {
              "type": "STRING",
              "value": "{:"
            },
            {
              "type": "STRING",
              "value": "{/"
            },
            {
              "type": "STRING",
              "value": "{"
            }
          ]
        }
      },
      "named": false,
      "value": "tag_delimiter"
    },
    "code": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_code_text"
          },
          {
            "type": "SYMBOL",
            "name": "_braces"
          },
          {
            "type": "SYMBOL",
            "name": "string"
          },
          {
            "type": "SYMBOL",
            "name": "char"
          },
          {
            "type": "SYMBOL",
            "name": "lifetime"
          }
        ]
      }
    },
    "_braces": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "code"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "_code_text": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "[^{}\"']+"
        }
      }
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\"([^\"\\\\]|\\\\.)*\""
      }
    },
    "char": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "'([^'\\\\]|\\\\.)'"
      }
    },
    "lifetime": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "'[a-zA-Z_][a-zA-Z0-9_]*"
      }
    },
    "text": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -2,
        "content": {
          "type": "PATTERN",
          "value": "[^{]+"
        }
      }
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}