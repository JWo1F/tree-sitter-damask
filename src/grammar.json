{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "rsc",
  "rules": {
    "document": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_node"
      }
    },
    "_node": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "comment"
        },
        {
          "type": "SYMBOL",
          "name": "html_comment"
        },
        {
          "type": "SYMBOL",
          "name": "doctype"
        },
        {
          "type": "SYMBOL",
          "name": "tag"
        },
        {
          "type": "SYMBOL",
          "name": "element"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        }
      ]
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "{#"
          },
          {
            "type": "PATTERN",
            "value": "\\s"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[^#]"
                },
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "#"
                    },
                    {
                      "type": "PATTERN",
                      "value": "[^}]"
                    }
                  ]
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "#}"
          }
        ]
      }
    },
    "tag": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "open",
          "content": {
            "type": "SYMBOL",
            "name": "tag_open"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "code"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "close",
          "content": {
            "type": "ALIAS",
            "content": {
              "type": "STRING",
              "value": "}"
            },
            "named": true,
            "value": "tag_delimiter"
          }
        }
      ]
    },
    "tag_open": {
      "type": "ALIAS",
      "content": {
        "type": "TOKEN",
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "{#"
            },
            {
              "type": "STRING",
              "value": "{@"
            },
            {
              "type": "STRING",
              "value": "{:"
            },
            {
              "type": "STRING",
              "value": "{/"
            },
            {
              "type": "STRING",
              "value": "{"
            }
          ]
        }
      },
      "named": false,
      "value": "tag_delimiter"
    },
    "code": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_code_text"
          },
          {
            "type": "SYMBOL",
            "name": "_braces"
          },
          {
            "type": "SYMBOL",
            "name": "string"
          },
          {
            "type": "SYMBOL",
            "name": "char"
          },
          {
            "type": "SYMBOL",
            "name": "lifetime"
          }
        ]
      }
    },
    "_braces": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "code"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "_code_text": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -1,
        "content": {
          "type": "PATTERN",
          "value": "[^{}\"']+"
        }
      }
    },
    "string": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\"([^\"\\\\]|\\\\.)*\""
      }
    },
    "char": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "'([^'\\\\]|\\\\.)'"
      }
    },
    "lifetime": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "'[a-zA-Z_][a-zA-Z0-9_]*"
      }
    },
    "doctype": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "<!"
          },
          {
            "type": "PATTERN",
            "value": "[^->][^>]*"
          },
          {
            "type": "STRING",
            "value": ">"
          }
        ]
      }
    },
    "html_comment": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "<!--"
          },
          {
            "type": "REPEAT",
            "content": {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PATTERN",
                  "value": "[^-]"
                },
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "-"
                    },
                    {
                      "type": "PATTERN",
                      "value": "[^-]"
                    }
                  ]
                },
                {
                  "type": "SEQ",
                  "members": [
                    {
                      "type": "STRING",
                      "value": "--"
                    },
                    {
                      "type": "PATTERN",
                      "value": "[^>]"
                    }
                  ]
                }
              ]
            }
          },
          {
            "type": "STRING",
            "value": "-->"
          }
        ]
      }
    },
    "element": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "<"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "IMMEDIATE_TOKEN",
              "content": {
                "type": "STRING",
                "value": "/"
              }
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "tag_name"
          }
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_ws"
              },
              {
                "type": "SYMBOL",
                "name": "_attribute"
              }
            ]
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_ws"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "/"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ">"
        }
      ]
    },
    "tag_name": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "component_name"
        },
        {
          "type": "SYMBOL",
          "name": "element_name"
        }
      ]
    },
    "component_name": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[A-Z][A-Za-z0-9_]*"
      }
    },
    "element_name": {
      "type": "IMMEDIATE_TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[a-z][A-Za-z0-9_.:-]*"
      }
    },
    "_ws": {
      "type": "PATTERN",
      "value": "\\s+"
    },
    "_attribute": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "spread"
        },
        {
          "type": "SYMBOL",
          "name": "class_directive"
        },
        {
          "type": "SYMBOL",
          "name": "class_attribute"
        },
        {
          "type": "SYMBOL",
          "name": "attribute"
        }
      ]
    },
    "spread": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "STRING",
          "value": "..."
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "code"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "class_attribute": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "directive_prefix"
          }
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "FIELD",
          "name": "value",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "quoted_value"
              },
              {
                "type": "SYMBOL",
                "name": "class_list"
              },
              {
                "type": "SYMBOL",
                "name": "class_brace"
              }
            ]
          }
        }
      ]
    },
    "class_directive": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "class_directive_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "="
                },
                {
                  "type": "FIELD",
                  "name": "value",
                  "content": {
                    "type": "CHOICE",
                    "members": [
                      {
                        "type": "SYMBOL",
                        "name": "quoted_value"
                      },
                      {
                        "type": "SYMBOL",
                        "name": "tag"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "class_directive_name": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "directive_prefix"
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "SYMBOL",
          "name": "class_name"
        }
      ]
    },
    "directive_prefix": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "STRING",
          "value": "class"
        }
      }
    },
    "class_name": {
      "type": "PATTERN",
      "value": "[A-Za-z0-9_.:\\/\\[\\]%-]+"
    },
    "attribute": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "name",
          "content": {
            "type": "SYMBOL",
            "name": "attribute_name"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "="
                },
                {
                  "type": "FIELD",
                  "name": "value",
                  "content": {
                    "type": "CHOICE",
                    "members": [
                      {
                        "type": "SYMBOL",
                        "name": "quoted_value"
                      },
                      {
                        "type": "SYMBOL",
                        "name": "tag"
                      }
                    ]
                  }
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "attribute_name": {
      "type": "PATTERN",
      "value": "[A-Za-z_][A-Za-z0-9_.:-]*"
    },
    "quoted_value": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "\""
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "tag"
                  },
                  {
                    "type": "ALIAS",
                    "content": {
                      "type": "TOKEN",
                      "content": {
                        "type": "PREC",
                        "value": -1,
                        "content": {
                          "type": "PATTERN",
                          "value": "[^\"{]+"
                        }
                      }
                    },
                    "named": true,
                    "value": "text"
                  }
                ]
              }
            },
            {
              "type": "STRING",
              "value": "\""
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "'"
            },
            {
              "type": "REPEAT",
              "content": {
                "type": "CHOICE",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "tag"
                  },
                  {
                    "type": "ALIAS",
                    "content": {
                      "type": "TOKEN",
                      "content": {
                        "type": "PREC",
                        "value": -1,
                        "content": {
                          "type": "PATTERN",
                          "value": "[^'{]+"
                        }
                      }
                    },
                    "named": true,
                    "value": "text"
                  }
                ]
              }
            },
            {
              "type": "STRING",
              "value": "'"
            }
          ]
        }
      ]
    },
    "class_list": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "["
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "SYMBOL",
                "name": "_ws"
              },
              {
                "type": "STRING",
                "value": ","
              },
              {
                "type": "SYMBOL",
                "name": "class_map"
              },
              {
                "type": "SYMBOL",
                "name": "class_string"
              },
              {
                "type": "SYMBOL",
                "name": "class_expr"
              }
            ]
          }
        },
        {
          "type": "STRING",
          "value": "]"
        }
      ]
    },
    "class_string": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\"([^\"\\\\]|\\\\.)*\""
      }
    },
    "class_expr": {
      "type": "ALIAS",
      "content": {
        "type": "TOKEN",
        "content": {
          "type": "PREC",
          "value": -1,
          "content": {
            "type": "PATTERN",
            "value": "[^,\\[\\]{}\"'\\s][^,\\[\\]{}\"']*"
          }
        }
      },
      "named": false,
      "value": "code"
    },
    "class_map": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "SYMBOL",
          "name": "_class_pairs"
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "class_brace": {
      "type": "SEQ",
      "members": [
        {
          "type": "STRING",
          "value": "{"
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "PREC_DYNAMIC",
                  "value": 1,
                  "content": {
                    "type": "SYMBOL",
                    "name": "_class_pairs"
                  }
                },
                {
                  "type": "SYMBOL",
                  "name": "class_code"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "}"
        }
      ]
    },
    "class_code": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "ALIAS",
            "content": {
              "type": "TOKEN",
              "content": {
                "type": "PREC",
                "value": -1,
                "content": {
                  "type": "PATTERN",
                  "value": "[^{}]+"
                }
              }
            },
            "named": true,
            "value": "code"
          },
          {
            "type": "SYMBOL",
            "name": "_braces"
          }
        ]
      }
    },
    "_class_pairs": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SYMBOL",
            "name": "_ws"
          },
          {
            "type": "STRING",
            "value": ","
          },
          {
            "type": "SYMBOL",
            "name": "class_pair"
          }
        ]
      }
    },
    "class_pair": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "key",
          "content": {
            "type": "SYMBOL",
            "name": "class_key"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_ws"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "FIELD",
          "name": "condition",
          "content": {
            "type": "SYMBOL",
            "name": "class_condition"
          }
        }
      ]
    },
    "class_key": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "\"([^\"\\\\]|\\\\.)*\""
      }
    },
    "class_condition": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "ALIAS",
            "content": {
              "type": "TOKEN",
              "content": {
                "type": "PREC",
                "value": -1,
                "content": {
                  "type": "PATTERN",
                  "value": "[^,{}]+"
                }
              }
            },
            "named": true,
            "value": "code"
          },
          {
            "type": "SYMBOL",
            "name": "_braces"
          }
        ]
      }
    },
    "text": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -2,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "PATTERN",
              "value": "([^{<]|<[^A-Za-z\\/!])+"
            },
            {
              "type": "PATTERN",
              "value": "<"
            }
          ]
        }
      }
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}